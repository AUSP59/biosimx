{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BioSimX Configuration",
  "type": "object",
  "properties": {
    "steps": {
      "type": "integer",
      "minimum": 1
    },
    "preset": {
      "type": "string",
      "enum": [
        "default",
        "fast",
        "accurate"
      ]
    },
    "output": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "steps",
    "preset",
    "output"
  ],
  "additionalProperties": false
}